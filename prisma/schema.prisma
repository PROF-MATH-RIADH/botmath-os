// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROFESSEUR
  ELEVE
  PARENT
}

model Utilisateur {
  id            Int               @id @default(autoincrement())
  nom           String
  prenom        String
  email         String            @unique
  mot_de_passe  String
  role          Role              @default(ELEVE)
  createdAt     DateTime          @default(now())
  scores        EvaluationScore[]
}

model Matiere {
  id          Int      @id @default(autoincrement())
  nom         String   @unique
  langue_mode String   @default("BILINGUE") // BILINGUE, FR, AR
  niveaux     Niveau[]
  createdAt   DateTime @default(now())
}

model Niveau {
  id          Int       @id @default(autoincrement())
  nom         String
  matiereId   Int
  matiere     Matiere   @relation(fields: [matiereId], references: [id])
  classes     Classe[]
  createdAt   DateTime  @default(now())
}

model Classe {
  id          Int       @id @default(autoincrement())
  nom         String
  niveauId    Int
  niveau      Niveau    @relation(fields: [niveauId], references: [id])
  periodes    Periode[]
  createdAt   DateTime  @default(now())
}

model Periode {
  id          Int        @id @default(autoincrement())
  nom         String
  classeId    Int
  classe      Classe     @relation(fields: [classeId], references: [id])
  chapitres   Chapitre[]
  createdAt   DateTime   @default(now())
}

model Chapitre {
  id          Int          @id @default(autoincrement())
  titre       String
  description String?
  periodeId   Int
  periode     Periode      @relation(fields: [periodeId], references: [id])
  paragraphes Paragraphe[]
  createdAt   DateTime     @default(now())
}

model Paragraphe {
  id          Int      @id @default(autoincrement())
  titre       String
  contenu     String   @db.Text
  chapitreId  Int
  chapitre    Chapitre @relation(fields: [chapitreId], references: [id])
  cours       Cours[]
  createdAt   DateTime @default(now())
}

model Cours {
  id                Int          @id @default(autoincrement())
  titre_fr          String?
  titre_ar          String?
  langue_mode       String       @default("BILINGUE") // Hérité ou surchargé
  id_chapitre       Int
  paragraphe        Paragraphe   @relation(fields: [id_chapitre], references: [id])
  id_theme          Int?
  theme             Theme?       @relation(fields: [id_theme], references: [id])
  type_activite     String       // savoir, evaluation, devoir, examen
  validation_admin  Boolean      @default(false)
  auto_script_global Json?       // { type, mode, payload, delay_s }
  diapos            Diapo[]
  eleven_config     Json?        // Configuration ElevenLabs
  createdAt         DateTime     @default(now())
}

model Diapo {
  id                  Int      @id @default(autoincrement())
  ordre               Int
  id_cours            Int
  cours               Cours    @relation(fields: [id_cours], references: [id])
  bg_color            String?
  bg_image            String?
  auto_script_type    String   @default("none") // none, script_nl, script
  auto_script_payload String?  @db.Text
  auto_script_delay_s Int      @default(0)
  blocs               Bloc[]
  createdAt           DateTime @default(now())
}

model Bloc {
  id            String   @id // Timestamp ou UUID
  custom_id     String?  // ID DOM personnalisé
  type          String   // texte, image, video, bouton, bouton_theme, revelation, flashcard, latex
  cible         String   @default("canvas") // canvas ou entete
  id_diapo      Int
  diapo         Diapo    @relation(fields: [id_diapo], references: [id])
  
  // Positionnement & Dimensions
  x             Float
  y             Float
  width         Float
  height        Float
  z_index       Int      @default(1)
  masque_depart Boolean  @default(false)

  // Contenu Bilingue
  contenu_fr    String?  @db.Text
  contenu_ar    String?  @db.Text
  texte_vocal_fr String? @db.Text
  texte_vocal_ar String? @db.Text

  // Médias
  url           String?  @db.Text
  url_fr        String?  @db.Text
  url_ar        String?  @db.Text
  audio_url     String?  @db.Text
  audio_url_fr  String?  @db.Text
  audio_url_ar  String?  @db.Text

  // Propriétés spécifiques (stockées en JSON pour la flexibilité)
  props         Json?    
  action        Json?    // { type, payload, payload2 }
  design        Json?    // { n_bg, h_bg, radius, etc. }

  createdAt     DateTime @default(now())
}

model Theme {
  id               Int        @id @default(autoincrement())
  nom              String
  config           Json       // Stocke toute la config design (boutonsTheme)
  cours            Cours[]
  createdAt        DateTime   @default(now())
}

model EvaluationScore {
  id             Int         @id @default(autoincrement())
  eleveId        Int
  eleve          Utilisateur @relation(fields: [eleveId], references: [id])
  note           Float
  dateEvaluation DateTime    @default(now())
}
